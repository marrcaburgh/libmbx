{
  "version": 6,
  "configurePresets": [
    {
      "name": "base",
      "displayName": "Base Configuration",
      "description": "Common settings for all builds",
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build/${presetName}",
      "cacheVariables": {
        "CMAKE_EXPORT_COMPILE_COMMANDS": "ON"
      }
    },
    {
      "name": "debug",
      "inherits": "base",
      "displayName": "Debug",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Debug",
        "CMAKE_C_FLAGS_DEBUG": "-g -O0 -Wall -Wextra -pedantic",
        "BUILD_TESTS": "ON",
        "BUILD_MATH": "OFF"
      }
    },
    {
      "name": "release-base",
      "inherits": "base",
      "hidden": true,
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_INTERPROCEDURAL_OPTIMIZATION": "ON",
        "CMAKE_C_FLAGS_RELEASE": "-O3 -march=native -DNDEBUG"
      }
    },
    {
      "name": "release",
      "inherits": "release-base",
      "displayName": "Release",
      "cacheVariables": {
        "BUILD_TESTS": "OFF",
        "BUILD_MATH": "OFF"
      }
    },
    {
      "name": "release-math",
      "inherits": "release-base",
      "displayName": "Release",
      "cacheVariables": {
        "BUILD_TESTS": "OFF",
        "BUILD_MATH": "ON"
      }
    },
    {
      "name": "release-tests",
      "inherits": "base",
      "displayName": "ReleaseTests",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release",
        "CMAKE_C_FLAGS_RELEASE": "-O3 -march=native -DNDEBUG",
        "BUILD_TESTS": "ON",
        "BUILD_MATH": "OFF"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "debug",
      "configurePreset": "debug"
    },
    {
      "name": "release-tests",
      "configurePreset": "release-tests"
    },
    {
      "name": "release",
      "configurePreset": "release"
    },
    {
      "name": "release-math",
      "configurePreset": "release-math"
    }
  ],
  "workflowPresets": [
    {
      "name": "develop",
      "steps": [
        {
          "type": "configure",
          "name": "debug"
        },
        {
          "type": "build",
          "name": "debug"
        }
      ]
    }
  ]
}
